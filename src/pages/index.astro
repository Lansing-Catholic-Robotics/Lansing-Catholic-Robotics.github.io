---
import Container from "@components/elements/Container.astro";
import Layout from "@layouts/Layout.astro";
import { siteConfig } from "site-config";

const quickstart = `pnpm create astro@latest --template ${siteConfig.githubRepo}`;
const quickstartId = "quickstart-command";

// Keep page content data-driven so the homepage stays easy to scan and edit.
const defaults = [
  "Astro 6 with Tailwind CSS 4 and DaisyUI 5",
  "Typed blog content collection with Markdown and MDX support",
  "SEO metadata, sitemap, robots.txt, and local SVG icons",
  "Dark mode toggle, skip link, and reduced-motion support",
];

const principles = [
  "DaisyUI is included on purpose as the default UI layer.",
  "Alpine is only used for tiny progressive enhancement needs.",
  "Examples are meant to be easy to delete, not hard to work around.",
  "Any escape hatches stay secondary to the default starter story.",
];

const starterTraits = [
  "Opinionated enough to be useful",
  "Small enough to understand quickly",
  "Ready for production work with low setup friction",
  "Easy to customize without losing control",
];
---

<Layout
  title="Cougar Claw Robotics"
  description="Lansing Catholic High School"
>
  <Container class="py-12 sm:py-16 lg:py-24">
    <!--
      Mobile-first structure:
      1. Start with a single-column stack that reads well on narrow screens.
      2. Introduce multi-column layouts only from `lg:` upward.
    -->
    <section class="space-y-8 lg:grid lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,24rem)] lg:gap-10 lg:space-y-0">
      <div class="space-y-6">
        <div class="space-y-4">
          <h1 class="max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl">
            Cougar Claw Robotics
          </h1>
          <img src="Logo_CougarClawRobotics_2026.jpg" alt="A bird sitting on a nest of eggs." />
          
          <h3 class="max-w-2xl text-2xl font-base-content tracking-tight sm:text-lg">
          We are a robotics team from Lansing Catholic High School in Lansing, MI competing in the FIRST robotics competition. Our mission is to teach students to become better thinkers, problem solvers, and teammates. By living out "Gracious Professionalism" they learn to put others first, bringing them closer to God and better disciples of Jesus.
          </h3>
          
        </div> 

        <!-- Full-width buttons on mobile are easier to tap and scan. -->
        

        
      </div>
    </section>

    <!-- Secondary information stays below the hero on mobile, then becomes a two-column grid. -->
    <section class="mt-10 grid gap-6 lg:mt-14 lg:grid-cols-2">
      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-4">
          <h2 class="card-title">Included by default</h2>
          <ul class="space-y-3 text-sm text-base-content/75 sm:text-base">
            {defaults.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-primary"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-4">
          <h2 class="card-title">Starter principles</h2>
          <ul class="space-y-3 text-sm text-base-content/75 sm:text-base">
            {principles.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-secondary"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </Container>
</Layout>

<script>
  function initCopyButtons() {
    document.querySelectorAll<HTMLButtonElement>('[data-copy-button]').forEach((button) => {
      if (button.dataset.copyReady === 'true') return;
      button.dataset.copyReady = 'true';

      button.addEventListener('click', async () => {
        const targetId = button.getAttribute('data-copy-target');
        const source = targetId ? document.getElementById(targetId) : null;
        if (!source) return;

        const originalLabel = button.textContent ?? 'Copy';

        try {
          await navigator.clipboard.writeText(source.textContent ?? '');
          button.textContent = 'Copied';
        } catch {
          button.textContent = 'Failed';
        }

        window.setTimeout(() => {
          button.textContent = originalLabel;
        }, 1200);
      });
    });
  }

  // Re-run after Astro view transitions so the button works on client navigation too.
  document.addEventListener('astro:page-load', initCopyButtons);
</script>
