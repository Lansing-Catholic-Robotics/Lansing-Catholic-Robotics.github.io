---
import Container from "@components/elements/Container.astro";
import Layout from "@layouts/Layout.astro";
import { siteConfig } from "site-config";
import FormPatterns from "@components/daisyui/FormPatterns.astro";
import Contact from "@components/daisyui/Contact.astro";


const quickstart = `pnpm create astro@latest --template ${siteConfig.githubRepo}`;
const quickstartId = "quickstart-command";

// Keep page content data-driven so the homepage stays easy to scan and edit.

---

<Layout
  title="Cougar Claw Robotics"
  description="Lansing Catholic High School"
>
  <Container class="py-12 sm:py-16 lg:py-24">
    <!--
      Mobile-first structure:
      1. Start with a single-column stack that reads well on narrow screens.
      2. Introduce multi-column layouts only from `lg:` upward.
    -->
    <section class="space-y-64 lg:gap-10 lg:space-y-0">
      <div class="space-y-9">
        <div class="space-y-9" >
          <h1 class="justify-self-center max-w-7xl text-7xl font-bold tracking-tight sm:text-3xl ">
            Cougar Claw Robotics
          </h1>
          <img class = "justify-self-center" src="Logo_CougarClawRobotics_2026.jpg" alt="Team Logo"/>
          
          <h3 class="max-w-5xl text-5xl font-base-content tracking-tight sm:text-2x1">
          We are a robotics team from Lansing Catholic High School in Lansing, MI competing in the FIRST robotics competition. Our mission is to teach students to become better thinkers, problem solvers, and teammates. By living out "Gracious Professionalism" they learn to put others first, bringing them closer to God and better disciples of Jesus.
          </h3>
        </div> 

        <!-- Full-width buttons on mobile are easier to tap and scan. -->
        <div class="space-y-9">
        
        <h1 class="max-w-4xl text-4xl font-bold tracking-tight sm:text-2xl" >
            Email<br>
            robotics@lansingcatholic.org
        </h1>
        
        <Contact />

        </div>

        
      </div>
    </section>
    </section>
  </Container>
  
</Layout>

<script>
  function initCopyButtons() {
    document.querySelectorAll<HTMLButtonElement>('[data-copy-button]').forEach((button) => {
      if (button.dataset.copyReady === 'true') return;
      button.dataset.copyReady = 'true';

      button.addEventListener('click', async () => {
        const targetId = button.getAttribute('data-copy-target');
        const source = targetId ? document.getElementById(targetId) : null;
        if (!source) return;

        const originalLabel = button.textContent ?? 'Copy';

        try {
          await navigator.clipboard.writeText(source.textContent ?? '');
          button.textContent = 'Copied';
        } catch {
          button.textContent = 'Failed';
        }

        window.setTimeout(() => {
          button.textContent = originalLabel;
        }, 1200);
      });
    });
  }

  // Re-run after Astro view transitions so the button works on client navigation too.
  document.addEventListener('astro:page-load', initCopyButtons);
</script>
