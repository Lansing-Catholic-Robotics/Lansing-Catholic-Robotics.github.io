---
import Container from "@components/elements/Container.astro";
import Sectionhead from "@components/elements/Sectionhead.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout title="Calendar">
  <div class="py-12 sm:py-16 sm:mx-10 lg:mx-10 lg:py-24 ">
    <p class = "font-bold justify-self-center m-10 text-[32px]/8">
      Team Calendar
    <p/>

    <section class="iframe-container mx-5">
      <div>
        <iframe src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FNew_York&title=Cougar%20Claw%20Robotics&src=cm9ib3RpY3NAbGFuc2luZ2NhdGhvbGljLm9yZw&color=%23039be5" style="border:solid 1px #777" width="100%" height="600" frameborder="0" scrolling="no" ></iframe>
      </div>
    </section>
  </div>
</Layout>